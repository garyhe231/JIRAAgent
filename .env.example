# ── JIRAAgent Environment Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values before deploying.

# REQUIRED: Change this to a long random string in production.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# Server
HOST=0.0.0.0
PORT=8009
WORKERS=4          # Number of uvicorn worker processes (set to 1 if using reload)
RELOAD=false       # Set to true for local development only

# Anthropic API key (required for AI features)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Admin account created on first startup
# If not set, defaults to admin / admin123 — CHANGE THIS IN PRODUCTION
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@yourcompany.com
